# Postgres connection string (e.g. from Neon: https://neon.tech)
DATABASE_URL=

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080

# Required for AI-based question generation/extraction (Generate, Paste (AI clean) modes)
GEMINI_API_KEY=

# Optional — only needed for the "From URL" import mode (scrapes a page via Firecrawl)
FIRECRAWL_API_KEY=
